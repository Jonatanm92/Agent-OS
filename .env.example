# ── Agent OS (Command pillar) ─────────────────────────────────────────────
# Port the Agent OS dashboard listens on
PORT=3001

# ── Free Claude Code proxy (CLI pillar) ───────────────────────────────────
# Base URL of the running FCC proxy (fcc-server). The README default is 8082;
# change it if you launched FCC on a different PORT.
FCC_BASE_URL=http://127.0.0.1:8082
# Must match ANTHROPIC_AUTH_TOKEN in the FCC Admin UI (default: freecc)
FCC_AUTH_TOKEN=freecc
# Model the dashboard sends to FCC. Claude tier names are routed by FCC to
# whatever provider you configured. The article's recommended free "Brain" is
# Owl Alpha — set MODEL="open_router/openrouter/owl-alpha" in the FCC Admin UI
# (1M context, native tool use, $0/token). This value is just the tier name FCC
# maps to that route.
MODEL=claude-sonnet-4-20250514

# ── Obsidian memory (Memory pillar) ───────────────────────────────────────
# Folder Agent OS reads/writes markdown memory into. Point this at your
# Obsidian vault so notes show up in the app too. Leave blank to use the default.
OBSIDIAN_VAULT_PATH=

# ── Workspace / project scoping ───────────────────────────────────────────
# Root folder under which each project gets its own scratch directory.
SCRATCH_DIR=~/freeclaude-scratch

# ── Access control (optional) ─────────────────────────────────────────────
# Leave blank for no login (fine on a trusted home network). Set a password to
# require it before the dashboard can be used — recommended if you reach it
# remotely (e.g. over Tailscale or any tunnel).
AGENT_OS_PASSWORD=
